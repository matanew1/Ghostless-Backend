{
  "name": "ghostless-backend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:all": "nest build api-gateway && nest build auth-service && nest build user-service && nest build chat-service && nest build scoring-service && nest build matching-service",
    "start:dev": "concurrently -n gw,auth,user,chat,score,match -c blue,green,yellow,magenta,cyan,red \"nest start api-gateway --watch\" \"nest start auth-service --watch\" \"nest start user-service --watch\" \"nest start chat-service --watch\" \"nest start scoring-service --watch\" \"nest start matching-service --watch\"",
    "start:dev:gateway": "nest start api-gateway --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "kafka:topics": "ts-node scripts/create-kafka-topics.ts",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest --watchman=false",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-auth-library": "^9.14.0",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.4.0",
    "kafkajs": "^2.2.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
