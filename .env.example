# Database
DATABASE_URL=postgresql://ghostless:ghostless@localhost:5432/ghostless

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (Redpanda external port)
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=ghostless

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OAuth
GOOGLE_CLIENT_ID=

# Service ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
CHAT_SERVICE_PORT=3003
SCORING_SERVICE_PORT=3004
MATCHING_SERVICE_PORT=3005

# Internal service URLs (gateway proxy targets)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
CHAT_SERVICE_URL=http://localhost:3003
SCORING_SERVICE_URL=http://localhost:3004
MATCHING_SERVICE_URL=http://localhost:3005
