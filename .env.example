# Database — Supabase PostgreSQL (direct connection)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase (Storage for avatars)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (Redpanda external port)
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=ghostless

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OAuth
GOOGLE_CLIENT_ID=

# Hugging Face Inference API (question classifier in chat-service)
# Empty token = chat-service falls back to the multilingual heuristic classifier.
HF_API_TOKEN=
# Per-request timeout. Warmup on boot uses a separate 30s window so the first
# user request after restart doesn't pay the cold-start cost.
HF_TIMEOUT_MS=5000

# Scoring recalc queue (BullMQ)
SCORING_RECALC_CONCURRENCY=8
SCORING_RECALC_DEBOUNCE_MS=10000

# Service ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
CHAT_SERVICE_PORT=3003
SCORING_SERVICE_PORT=3004
MATCHING_SERVICE_PORT=3005

# Internal service URLs (gateway proxy targets)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
CHAT_SERVICE_URL=http://localhost:3003
SCORING_SERVICE_URL=http://localhost:3004
MATCHING_SERVICE_URL=http://localhost:3005
