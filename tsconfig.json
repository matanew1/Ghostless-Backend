{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@prisma/client": ["generated/prisma/client"],
      "@prisma/client/*": ["generated/prisma/*"],
      "@ghostless/contracts": ["libs/contracts/src"],
      "@ghostless/contracts/*": ["libs/contracts/src/*"],
      "@ghostless/common": ["libs/common/src"],
      "@ghostless/common/*": ["libs/common/src/*"],
      "@ghostless/kafka": ["libs/kafka/src"],
      "@ghostless/kafka/*": ["libs/kafka/src/*"],
      "@ghostless/database": ["libs/database/src"],
      "@ghostless/database/*": ["libs/database/src/*"],
      "@ghostless/network": ["libs/network/src"],
      "@ghostless/network/*": ["libs/network/src/*"]
    }
  }
}
